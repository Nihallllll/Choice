{
  "name": "@byok/backend-node",
  "version": "0.1.0",
  "description": "Express middleware and LangChain integration for BYOK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@langchain/core": "^0.3.80",
    "@langchain/openai": "^0.3.17"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "express": "^4.22.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  }
}
